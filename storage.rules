rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Driver's license photos are sensitive ID data.
    // ONLY the authenticated owner can read or write them directly.
    // Customer uploads (from the public signing link) go through a server
    // API route using the Admin SDK, which bypasses these rules — so an
    // unauthenticated visitor can never read or write a DL image.
    match /dl/{orderId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Lock everything else by default.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
