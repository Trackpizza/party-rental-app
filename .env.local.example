# ============================================================
# party-rental-app — environment config
# Copy this file to .env.local and fill in the values.
# This is the ONLY file that changes per client/deployment.
# ============================================================

# --- Firebase Web (client) config — from Firebase Console > Project Settings > General > Your apps ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server) — from Project Settings > Service Accounts > Generate new private key ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n escapes, wrapped in quotes:
FIREBASE_PRIVATE_KEY=""

# --- Business / branding (shown on forms, receipts, customer page) ---
NEXT_PUBLIC_BUSINESS_NAME="Party Supplies La Poblanita 2"
NEXT_PUBLIC_BUSINESS_PHONE="818.982.5234"
NEXT_PUBLIC_OWNER_CELL="818.321.0663"
NEXT_PUBLIC_BUSINESS_ADDRESS="12034 Vanowen Street, North Hollywood, CA 91605"
NEXT_PUBLIC_BUSINESS_WEBSITE="https://ezbookaparty.com"
NEXT_PUBLIC_ZELLE_NUMBER="747.389.8112"
# Public base URL of the deployed app (used to build customer share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Google Places address autocomplete (optional) ---
# Maps JS API key with Places API enabled, restricted by HTTP referrer.
# Leave blank to use a plain address field.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Email (Gmail SMTP) — for receipts + setup-photo emails ---
# The Gmail account must have 2-Step Verification on; generate an App Password
# at myaccount.google.com > Security > App passwords (16 chars, no spaces).
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM_NAME="Party Supplies La Poblanita 2"
